NODE_ENV=development

# Database
DATABASE_URL=postgresql://lumina:lumina_dev_password@localhost:5433/lumina

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=lumina_meili_dev_key

# Auth
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MAPBOX_TOKEN=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Stripe — use TEST MODE keys for local development (sk_test_... / pk_test_...).
# Get them at: https://dashboard.stripe.com/test/apikeys
# For local webhook forwarding:  stripe listen --forward-to localhost:3000/api/payments/webhook
# The CLI prints STRIPE_WEBHOOK_SECRET on start — paste it below.
# Test card: 4242 4242 4242 4242  (any future expiry, any CVC, any ZIP)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Email / SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@luminarentals.com

# AI (optional — enables semantic search and AI description generator)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OpenTelemetry (optional — set to enable distributed tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Indexer health port
HEALTH_PORT=3001
